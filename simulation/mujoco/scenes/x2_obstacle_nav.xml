<!--
  AGIBot X2 Obstacle Navigation Scene for MuJoCo.

  This scene contains:
  - AGIBot X2 humanoid robot
  - 3 box obstacles in a corridor configuration
  - Goal marker
  - Ground plane with friction

  AGIBot X2 velocity limits:
    vx: [0, 1.0] m/s
    wz: [-0.3, 0.3] rad/s

  Used for Tier 1 RoboPay bounty validation.
-->
<mujoco model="x2_obstacle_navigation">
  <compiler angle="radian" meshdir="." autolimits="true"/>

  <option timestep="0.001" gravity="0 0 -9.81" integrator="implicitfast">
    <flag/>
  </option>

  <default>
    <joint armature="0.01" damping="0.1"/>
    <geom condim="4" friction="1.0 0.005 0.0001"/>
    <motor ctrllimited="true"/>
  </default>

  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.4 0.4 0.4" rgb2="0.5 0.5 0.5" width="512" height="512"/>
    <material name="grid_mat" texture="grid" texrepeat="10 10" reflectance="0.1"/>
    <material name="obstacle_mat" rgba="0.8 0.2 0.2 1"/>
    <material name="goal_mat" rgba="0.2 0.8 0.2 0.5"/>
    <material name="robot_mat" rgba="0.2 0.4 0.7 1"/>
  </asset>

  <worldbody>
    <!-- Ground -->
    <geom name="ground" type="plane" size="20 20 0.1" material="grid_mat"/>
    <light name="top_light" pos="0 0 10" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <light name="side_light" pos="5 5 5" dir="-1 -1 -1" diffuse="0.4 0.4 0.4"/>

    <!-- AGIBot X2 Robot (humanoid body) -->
    <body name="torso" pos="0 0 0.85">
      <inertial mass="45.0" pos="0 0 0" diaginertia="1.5 1.5 1.5"/>
      <geom name="torso_geom" type="capsule" size="0.18" fromto="0 -0.14 0 0 0.14 0" material="robot_mat"/>

      <!-- Head -->
      <body name="head" pos="0 0 0.28">
        <inertial mass="3.0" pos="0 0 0" diaginertia="0.15 0.15 0.15"/>
        <geom name="head_geom" type="sphere" size="0.13" material="robot_mat"/>
      </body>

      <!-- Left Arm -->
      <body name="left_upper_arm" pos="0 0.22 0.12">
        <inertial mass="2.5" pos="0 0 -0.15" diaginertia="0.06 0.06 0.06"/>
        <joint name="left_shoulder_pitch" type="hinge" axis="1 0 0" range="-3.14 3.14"/>
        <geom name="left_upper_arm_geom" type="capsule" size="0.045" fromto="0 0 0 0 0 -0.32" material="robot_mat"/>

        <body name="left_lower_arm" pos="0 0 -0.32">
          <inertial mass="1.8" pos="0 0 -0.15" diaginertia="0.04 0.04 0.04"/>
          <joint name="left_elbow" type="hinge" axis="0 1 0" range="-2.5 0"/>
          <geom name="left_lower_arm_geom" type="capsule" size="0.038" fromto="0 0 0 0 0 -0.3" material="robot_mat"/>
        </body>
      </body>

      <!-- Right Arm -->
      <body name="right_upper_arm" pos="0 -0.22 0.12">
        <inertial mass="2.5" pos="0 0 -0.15" diaginertia="0.06 0.06 0.06"/>
        <joint name="right_shoulder_pitch" type="hinge" axis="1 0 0" range="-3.14 3.14"/>
        <geom name="right_upper_arm_geom" type="capsule" size="0.045" fromto="0 0 0 0 0 -0.32" material="robot_mat"/>

        <body name="right_lower_arm" pos="0 0 -0.32">
          <inertial mass="1.8" pos="0 0 -0.15" diaginertia="0.04 0.04 0.04"/>
          <joint name="right_elbow" type="hinge" axis="0 1 0" range="-2.5 0"/>
          <geom name="right_lower_arm_geom" type="capsule" size="0.038" fromto="0 0 0 0 0 -0.3" material="robot_mat"/>
        </body>
      </body>

      <!-- Left Leg -->
      <body name="left_thigh" pos="0 0.12 -0.22">
        <inertial mass="6.0" pos="0 0 -0.22" diaginertia="0.12 0.12 0.12"/>
        <joint name="left_hip_pitch" type="hinge" axis="1 0 0" range="-1.5 1.5"/>
        <geom name="left_thigh_geom" type="capsule" size="0.065" fromto="0 0 0 0 0 -0.44" material="robot_mat"/>

        <body name="left_shin" pos="0 0 -0.44">
          <inertial mass="4.5" pos="0 0 -0.2" diaginertia="0.09 0.09 0.09"/>
          <joint name="left_knee" type="hinge" axis="0 1 0" range="-2.5 0"/>
          <geom name="left_shin_geom" type="capsule" size="0.055" fromto="0 0 0 0 0 -0.4" material="robot_mat"/>

          <body name="left_foot" pos="0 0 -0.4">
            <inertial mass="1.2" pos="0 0 -0.03" diaginertia="0.015 0.015 0.015"/>
            <joint name="left_ankle" type="hinge" axis="0 1 0" range="-0.5 0.5"/>
            <geom name="left_foot_geom" type="box" size="0.1 0.05 0.03" pos="0 0 -0.03" material="robot_mat"/>
            <site name="left_foot_site" pos="0 0 -0.06"/>
          </body>
        </body>
      </body>

      <!-- Right Leg -->
      <body name="right_thigh" pos="0 -0.12 -0.22">
        <inertial mass="6.0" pos="0 0 -0.22" diaginertia="0.12 0.12 0.12"/>
        <joint name="right_hip_pitch" type="hinge" axis="1 0 0" range="-1.5 1.5"/>
        <geom name="right_thigh_geom" type="capsule" size="0.065" fromto="0 0 0 0 0 -0.44" material="robot_mat"/>

        <body name="right_shin" pos="0 0 -0.44">
          <inertial mass="4.5" pos="0 0 -0.2" diaginertia="0.09 0.09 0.09"/>
          <joint name="right_knee" type="hinge" axis="0 1 0" range="-2.5 0"/>
          <geom name="right_shin_geom" type="capsule" size="0.055" fromto="0 0 0 0 0 -0.4" material="robot_mat"/>

          <body name="right_foot" pos="0 0 -0.4">
            <inertial mass="1.2" pos="0 0 -0.03" diaginertia="0.015 0.015 0.015"/>
            <joint name="right_ankle" type="hinge" axis="0 1 0" range="-0.5 0.5"/>
            <geom name="right_foot_geom" type="box" size="0.1 0.05 0.03" pos="0 0 -0.03" material="robot_mat"/>
            <site name="right_foot_site" pos="0 0 -0.06"/>
          </body>
        </body>
      </body>

      <!-- Free joint for base locomotion -->
      <freejoint name="root"/>
    </body>

    <!-- Obstacles -->
    <body name="obstacle_1" pos="2.5 0 0.5" mocap="true">
      <geom name="obs1_geom" type="box" size="0.5 0.5 0.5" material="obstacle_mat" contype="1" conaffinity="1"/>
    </body>

    <body name="obstacle_2" pos="5.0 1.5 0.5" mocap="true">
      <geom name="obs2_geom" type="box" size="0.4 0.4 0.6" material="obstacle_mat" contype="1" conaffinity="1"/>
    </body>

    <body name="obstacle_3" pos="7.0 -1.0 0.5" mocap="true">
      <geom name="obs3_geom" type="cylinder" size="0.3 0.5" material="obstacle_mat" contype="1" conaffinity="1"/>
    </body>

    <!-- Goal marker -->
    <body name="goal" pos="10.0 0 0.05">
      <geom name="goal_geom" type="cylinder" size="0.3 0.05" material="goal_mat" contype="0" conaffinity="0"/>
      <site name="goal_site" pos="0 0 0.05"/>
    </body>
  </worldbody>

  <!-- Sensors for metrics -->
  <sensor>
    <framepos name="torso_pos" objtype="body" objname="torso"/>
  </sensor>

  <!-- Actuators for locomotion -->
  <!-- AGIBot X2: vx [0, 1.0], wz [-0.3, 0.3] -->
  <actuator>
    <motor name="root_x" joint="root" gear="1 0 0 0 0 0" ctrlrange="-100 100"/>
    <motor name="root_y" joint="root" gear="0 1 0 0 0 0" ctrlrange="-100 100"/>
    <motor name="root_yaw" joint="root" gear="0 0 0 0 0 1" ctrlrange="-50 50"/>
    <position name="left_hip_act" joint="left_hip_pitch" kp="220" ctrlrange="-1.5 1.5"/>
    <position name="left_knee_act" joint="left_knee" kp="220" ctrlrange="-2.5 0"/>
    <position name="left_ankle_act" joint="left_ankle" kp="60" ctrlrange="-0.5 0.5"/>
    <position name="right_hip_act" joint="right_hip_pitch" kp="220" ctrlrange="-1.5 1.5"/>
    <position name="right_knee_act" joint="right_knee" kp="220" ctrlrange="-2.5 0"/>
    <position name="right_ankle_act" joint="right_ankle" kp="60" ctrlrange="-0.5 0.5"/>
    <position name="left_shoulder_act" joint="left_shoulder_pitch" kp="120" ctrlrange="-3.14 3.14"/>
    <position name="left_elbow_act" joint="left_elbow" kp="120" ctrlrange="-2.5 0"/>
    <position name="right_shoulder_act" joint="right_shoulder_pitch" kp="120" ctrlrange="-3.14 3.14"/>
    <position name="right_elbow_act" joint="right_elbow" kp="120" ctrlrange="-2.5 0"/>
  </actuator>
</mujoco>
