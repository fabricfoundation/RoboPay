<!--
  Unitree Go2 Robot Obstacle Navigation Scene for MuJoCo.
  Robot type: quadruped
  Velocity limits: vx [0, 1.5], wz [-1.0, 1.0]
-->
<mujoco model="unitree-go2_obstacle_navigation">
  <compiler angle="radian" meshdir="." autolimits="true"/>
  <option timestep="0.001" gravity="0 0 -9.81" integrator="implicitfast">
    <flag sensornoise="disable"/>
  </option>
  <default>
    <joint armature="0.01" damping="0.1"/>
    <geom condim="4" friction="1.0 0.005 0.0001"/>
    <motor ctrllimited="true"/>
  </default>
  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.4 0.4 0.4" rgb2="0.5 0.5 0.5" width="512" height="512"/>
    <material name="grid_mat" texture="grid" texrepeat="10 10" reflectance="0.1"/>
    <material name="obstacle_mat" rgba="0.8 0.2 0.2 1"/>
    <material name="goal_mat" rgba="0.2 0.8 0.2 0.5"/>
    <material name="robot_mat" rgba="0.3 0.3 0.3 1"/>
  </asset>
  <worldbody>
    <geom name="ground" type="plane" size="20 20 0.1" material="grid_mat"/>
    <light name="top_light" pos="0 0 10" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <light name="side_light" pos="5 5 5" dir="-1 -1 -1" diffuse="0.4 0.4 0.4"/>
    <body name="torso" pos="0 0 0.35">
      <inertial mass="12.0" pos="0 0 0" diaginertia="0.5 0.5 0.5"/>
      <geom name="torso_geom" type="capsule" size="0.12" fromto="-0.15 0 -0.05 0.15 0 -0.05" material="robot_mat"/>
      <body name="fl_hip" pos="0.15 0.08 0">
        <inertial mass="1.5" pos="0 0 -0.1" diaginertia="0.02 0.02 0.02"/>
        <joint name="fl_hip_joint" type="hinge" axis="1 0 0" range="-0.5 0.5"/>
        <geom name="fl_upper" type="capsule" size="0.04" fromto="0 0 0 0 0 -0.15" material="robot_mat"/>
        <body name="fl_knee" pos="0 0 -0.15">
          <inertial mass="1.0" pos="0 0 -0.12" diaginertia="0.015 0.015 0.015"/>
          <joint name="fl_knee_joint" type="hinge" axis="0 1 0" range="-2.0 0"/>
          <geom name="fl_lower" type="capsule" size="0.03" fromto="0 0 0 0 0 -0.2" material="robot_mat"/>
          <body name="fl_foot" pos="0 0 -0.2">
            <inertial mass="0.3" pos="0 0 0" diaginertia="0.002 0.002 0.002"/>
            <geom name="fl_foot_geom" type="sphere" size="0.03" material="robot_mat"/>
            <site name="fl_foot_site" pos="0 0 0"/>
          </body>
        </body>
      </body>
      <body name="fr_hip" pos="0.15 -0.08 0">
        <inertial mass="1.5" pos="0 0 -0.1" diaginertia="0.02 0.02 0.02"/>
        <joint name="fr_hip_joint" type="hinge" axis="1 0 0" range="-0.5 0.5"/>
        <geom name="fr_upper" type="capsule" size="0.04" fromto="0 0 0 0 0 -0.15" material="robot_mat"/>
        <body name="fr_knee" pos="0 0 -0.15">
          <inertial mass="1.0" pos="0 0 -0.12" diaginertia="0.015 0.015 0.015"/>
          <joint name="fr_knee_joint" type="hinge" axis="0 1 0" range="-2.0 0"/>
          <geom name="fr_lower" type="capsule" size="0.03" fromto="0 0 0 0 0 -0.2" material="robot_mat"/>
          <body name="fr_foot" pos="0 0 -0.2">
            <inertial mass="0.3" pos="0 0 0" diaginertia="0.002 0.002 0.002"/>
            <geom name="fr_foot_geom" type="sphere" size="0.03" material="robot_mat"/>
            <site name="fr_foot_site" pos="0 0 0"/>
          </body>
        </body>
      </body>
      <body name="rl_hip" pos="-0.15 0.08 0">
        <inertial mass="1.5" pos="0 0 -0.1" diaginertia="0.02 0.02 0.02"/>
        <joint name="rl_hip_joint" type="hinge" axis="1 0 0" range="-0.5 0.5"/>
        <geom name="rl_upper" type="capsule" size="0.04" fromto="0 0 0 0 0 -0.15" material="robot_mat"/>
        <body name="rl_knee" pos="0 0 -0.15">
          <inertial mass="1.0" pos="0 0 -0.12" diaginertia="0.015 0.015 0.015"/>
          <joint name="rl_knee_joint" type="hinge" axis="0 1 0" range="-2.0 0"/>
          <geom name="rl_lower" type="capsule" size="0.03" fromto="0 0 0 0 0 -0.2" material="robot_mat"/>
          <body name="rl_foot" pos="0 0 -0.2">
            <inertial mass="0.3" pos="0 0 0" diaginertia="0.002 0.002 0.002"/>
            <geom name="rl_foot_geom" type="sphere" size="0.03" material="robot_mat"/>
            <site name="rl_foot_site" pos="0 0 0"/>
          </body>
        </body>
      </body>
      <body name="rr_hip" pos="-0.15 -0.08 0">
        <inertial mass="1.5" pos="0 0 -0.1" diaginertia="0.02 0.02 0.02"/>
        <joint name="rr_hip_joint" type="hinge" axis="1 0 0" range="-0.5 0.5"/>
        <geom name="rr_upper" type="capsule" size="0.04" fromto="0 0 0 0 0 -0.15" material="robot_mat"/>
        <body name="rr_knee" pos="0 0 -0.15">
          <inertial mass="1.0" pos="0 0 -0.12" diaginertia="0.015 0.015 0.015"/>
          <joint name="rr_knee_joint" type="hinge" axis="0 1 0" range="-2.0 0"/>
          <geom name="rr_lower" type="capsule" size="0.03" fromto="0 0 0 0 0 -0.2" material="robot_mat"/>
          <body name="rr_foot" pos="0 0 -0.2">
            <inertial mass="0.3" pos="0 0 0" diaginertia="0.002 0.002 0.002"/>
            <geom name="rr_foot_geom" type="sphere" size="0.03" material="robot_mat"/>
            <site name="rr_foot_site" pos="0 0 0"/>
          </body>
        </body>
      </body>
      <freejoint name="root"/>
    </body>
    <body name="obstacle_1" pos="2.5 0 0.5" mocap="true">
      <geom name="obs1_geom" type="box" size="0.5 0.5 0.5" material="obstacle_mat" contype="1" conaffinity="1"/>
    </body>
    <body name="obstacle_2" pos="5.0 1.5 0.5" mocap="true">
      <geom name="obs2_geom" type="box" size="0.4 0.4 0.6" material="obstacle_mat" contype="1" conaffinity="1"/>
    </body>
    <body name="obstacle_3" pos="7.0 -1.0 0.5" mocap="true">
      <geom name="obs3_geom" type="cylinder" size="0.3 0.5" material="obstacle_mat" contype="1" conaffinity="1"/>
    </body>
    <body name="goal" pos="10.0 0 0.05">
      <geom name="goal_geom" type="cylinder" size="0.3 0.05" material="goal_mat" contype="0" conaffinity="0"/>
      <site name="goal_site" pos="0 0 0.05"/>
    </body>
  </worldbody>
  <sensor>
    <framepos name="torso_pos" objtype="body" objname="torso"/>
    <framevel name="torso_vel" objtype="body" objname="torso"/>
    <touch name="fl_foot_touch" site="fl_foot_site"/>
    <touch name="fr_foot_touch" site="fr_foot_site"/>
    <touch name="rl_foot_touch" site="rl_foot_site"/>
    <touch name="rr_foot_touch" site="rr_foot_site"/>
    <framepos name="goal_pos" objtype="site" objname="goal_site"/>
  </sensor>
  <actuator>
    <motor name="root_x" joint="root" gear="1 0 0 0 0 0" ctrlrange="-100 100"/>
    <motor name="root_y" joint="root" gear="0 1 0 0 0 0" ctrlrange="-100 100"/>
    <motor name="root_yaw" joint="root" gear="0 0 0 0 0 1" ctrlrange="-50 50"/>
    <position name="fl_hip_act" joint="fl_hip_joint" kp="150" ctrlrange="-0.5 0.5"/>
    <position name="fl_knee_act" joint="fl_knee_joint" kp="150" ctrlrange="-2.0 0"/>
    <position name="fr_hip_act" joint="fr_hip_joint" kp="150" ctrlrange="-0.5 0.5"/>
    <position name="fr_knee_act" joint="fr_knee_joint" kp="150" ctrlrange="-2.0 0"/>
    <position name="rl_hip_act" joint="rl_hip_joint" kp="150" ctrlrange="-0.5 0.5"/>
    <position name="rl_knee_act" joint="rl_knee_joint" kp="150" ctrlrange="-2.0 0"/>
    <position name="rr_hip_act" joint="rr_hip_joint" kp="150" ctrlrange="-0.5 0.5"/>
    <position name="rr_knee_act" joint="rr_knee_joint" kp="150" ctrlrange="-2.0 0"/>
  </actuator>
</mujoco>
