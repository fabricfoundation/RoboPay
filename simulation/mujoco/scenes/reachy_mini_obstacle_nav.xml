<!--
  Hugging Face Reachy Mini Robot Obstacle Navigation Scene for MuJoCo.
  Robot type: mini
  Velocity limits: vx [0, 0.5], wz [-0.3, 0.3]
-->
<mujoco model="hugging-face-reachy-mini_obstacle_navigation">
  <compiler angle="radian" meshdir="." autolimits="true"/>
  <option timestep="0.001" gravity="0 0 -9.81" integrator="implicitfast">
    <flag sensornoise="disable"/>
  </option>
  <default>
    <joint armature="0.01" damping="0.1"/>
    <geom condim="4" friction="1.0 0.005 0.0001"/>
    <motor ctrllimited="true"/>
  </default>
  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.4 0.4 0.4" rgb2="0.5 0.5 0.5" width="512" height="512"/>
    <material name="grid_mat" texture="grid" texrepeat="10 10" reflectance="0.1"/>
    <material name="obstacle_mat" rgba="0.8 0.2 0.2 1"/>
    <material name="goal_mat" rgba="0.2 0.8 0.2 0.5"/>
    <material name="robot_mat" rgba="0.3 0.3 0.3 1"/>
  </asset>
  <worldbody>
    <geom name="ground" type="plane" size="20 20 0.1" material="grid_mat"/>
    <light name="top_light" pos="0 0 10" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <light name="side_light" pos="5 5 5" dir="-1 -1 -1" diffuse="0.4 0.4 0.4"/>
    <body name="torso" pos="0 0 0.20">
      <inertial mass="3.0" pos="0 0 0" diaginertia="0.05 0.05 0.05"/>
      <geom name="torso_geom" type="sphere" size="0.08" material="robot_mat"/>
      <body name="left_leg" pos="0 0.04 -0.05">
        <inertial mass="0.3" pos="0 0 -0.06" diaginertia="0.005 0.005 0.005"/>
        <joint name="left_hip" type="hinge" axis="1 0 0" range="-1.0 1.0"/>
        <geom name="left_leg_geom" type="capsule" size="0.02" fromto="0 0 0 0 0 -0.1" material="robot_mat"/>
        <body name="left_foot" pos="0 0 -0.1">
          <inertial mass="0.1" pos="0 0 0" diaginertia="0.001 0.001 0.001"/>
          <geom name="left_foot_geom" type="sphere" size="0.025" material="robot_mat"/>
          <site name="left_foot_site" pos="0 0 0"/>
        </body>
      </body>
      <body name="right_leg" pos="0 -0.04 -0.05">
        <inertial mass="0.3" pos="0 0 -0.06" diaginertia="0.005 0.005 0.005"/>
        <joint name="right_hip" type="hinge" axis="1 0 0" range="-1.0 1.0"/>
        <geom name="right_leg_geom" type="capsule" size="0.02" fromto="0 0 0 0 0 -0.1" material="robot_mat"/>
        <body name="right_foot" pos="0 0 -0.1">
          <inertial mass="0.1" pos="0 0 0" diaginertia="0.001 0.001 0.001"/>
          <geom name="right_foot_geom" type="sphere" size="0.025" material="robot_mat"/>
          <site name="right_foot_site" pos="0 0 0"/>
        </body>
      </body>
      <freejoint name="root"/>
    </body>
    <body name="obstacle_1" pos="2.5 0 0.5" mocap="true">
      <geom name="obs1_geom" type="box" size="0.5 0.5 0.5" material="obstacle_mat" contype="1" conaffinity="1"/>
    </body>
    <body name="obstacle_2" pos="5.0 1.5 0.5" mocap="true">
      <geom name="obs2_geom" type="box" size="0.4 0.4 0.6" material="obstacle_mat" contype="1" conaffinity="1"/>
    </body>
    <body name="obstacle_3" pos="7.0 -1.0 0.5" mocap="true">
      <geom name="obs3_geom" type="cylinder" size="0.3 0.5" material="obstacle_mat" contype="1" conaffinity="1"/>
    </body>
    <body name="goal" pos="10.0 0 0.05">
      <geom name="goal_geom" type="cylinder" size="0.3 0.05" material="goal_mat" contype="0" conaffinity="0"/>
      <site name="goal_site" pos="0 0 0.05"/>
    </body>
  </worldbody>
  <sensor>
    <framepos name="torso_pos" objtype="body" objname="torso"/>
    <framevel name="torso_vel" objtype="body" objname="torso"/>
    <touch name="left_foot_touch" site="left_foot_site"/>
    <touch name="right_foot_touch" site="right_foot_site"/>
    <framepos name="goal_pos" objtype="site" objname="goal_site"/>
  </sensor>
  <actuator>
    <motor name="root_x" joint="root" gear="1 0 0 0 0 0" ctrlrange="-50 50"/>
    <motor name="root_y" joint="root" gear="0 1 0 0 0 0" ctrlrange="-50 50"/>
    <motor name="root_yaw" joint="root" gear="0 0 0 0 0 1" ctrlrange="-25 25"/>
    <position name="left_hip_act" joint="left_hip" kp="50" ctrlrange="-1.0 1.0"/>
    <position name="right_hip_act" joint="right_hip" kp="50" ctrlrange="-1.0 1.0"/>
  </actuator>
</mujoco>
