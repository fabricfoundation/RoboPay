#VRML_SIM R2023b utf8

WorldInfo {
  info [ "Hugging Face Reachy Mini — Webots Sim-to-Sim Cross-Simulator Validation" ]
  title "reachy_mini_tabletop_tracking"
  basicTimeStep 5
  FPS 60
}

Viewpoint {
  orientation -0.15 0.85 0.5 0.9
  position 1.6 -1.3 1.1
  follow "reachy_mini"
}

Background { skyColor [ 0.4 0.7 1.0 ] }

PointLight {
  attenuation 0 0 1
  color 1 1 1
  intensity 3
  location 0.5 -0.5 1.5
  castShadows TRUE
}

PointLight {
  attenuation 0 0 1
  color 0.9 0.9 1
  intensity 1.5
  location -0.5 0.5 1.2
}

# ── Table ──────────────────────────────────────────────────────────────────────
Solid {
  translation 0.6 0 0.0
  name "table"
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.55 0.38 0.18 roughness 0.6 metalness 0 }
      geometry Box { size 0.8 1.0 0.05 }
    }
  ]
  boundingObject Box { size 0.8 1.0 0.05 }
}

# ── Apple ─────────────────────────────────────────────────────────────────────
Solid {
  translation 0.6 -0.2 0.07
  name "APPLE"
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.92 0.12 0.08 roughness 0.2 metalness 0 }
      geometry Sphere { radius 0.04 }
    }
  ]
  boundingObject Sphere { radius 0.04 }
  physics Physics { density 300 }
}

# ── Croissant ─────────────────────────────────────────────────────────────────
Solid {
  translation 0.6 0.1 0.065
  name "CROISSANT"
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.82 0.52 0.18 roughness 0.7 metalness 0 }
      geometry Box { size 0.09 0.05 0.04 }
    }
  ]
  boundingObject Box { size 0.09 0.05 0.04 }
  physics Physics { density 200 }
}

# ── Duck ──────────────────────────────────────────────────────────────────────
Solid {
  translation 0.6 0.3 0.065
  name "DUCK"
  children [
    # Body
    Shape {
      appearance PBRAppearance { baseColor 0.95 0.95 0.05 roughness 0.3 metalness 0 }
      geometry Sphere { radius 0.04 }
    }
    # Head
    Solid {
      translation 0.0 0 0.052
      children [
        Shape {
          appearance PBRAppearance { baseColor 0.95 0.95 0.05 roughness 0.3 metalness 0 }
          geometry Sphere { radius 0.025 }
        }
      ]
    }
    # Beak
    Solid {
      translation 0.025 0 0.055
      children [
        Shape {
          appearance PBRAppearance { baseColor 0.95 0.55 0.1 roughness 0.4 metalness 0 }
          geometry Box { size 0.02 0.012 0.008 }
        }
      ]
    }
  ]
  boundingObject Sphere { radius 0.05 }
  physics Physics { density 100 }
}

# ── Reachy Mini Robot ─────────────────────────────────────────────────────────
Robot {
  translation 0 0 0.0
  name "reachy_mini"
  controller "reachy_mini_controller"
  supervisor TRUE
  children [

    # Base (dark cylinder — fixed)
    Solid {
      translation 0 0 0.05
      name "base_foot"
      children [
        Shape {
          appearance PBRAppearance { baseColor 0.2 0.2 0.25 roughness 0.45 metalness 0.15 }
          geometry Cylinder { height 0.1 radius 0.09 }
        }
      ]
      boundingObject Cylinder { height 0.1 radius 0.09 }
      physics Physics {}
    }

    # Yaw joint — spins the whole torso+head assembly
    HingeJoint {
      jointParameters HingeJointParameters {
        axis 0 0 1
        anchor 0 0 0.1
      }
      device [
        RotationalMotor {
          name "yaw_body"
          minPosition -2.79
          maxPosition  2.79
          maxVelocity  3.0
        }
        PositionSensor { name "yaw_body_sensor" }
      ]
      endPoint Solid {
        translation 0 0 0.1
        name "torso"
        children [

          # Torso shell — white cylinder
          Shape {
            appearance PBRAppearance { baseColor 0.93 0.93 0.97 roughness 0.15 metalness 0 }
            geometry Cylinder { height 0.22 radius 0.062 }
          }

          # Neck base plate (dark disc) — on top of torso
          Solid {
            translation 0 0 0.135
            name "neck_plate"
            children [
              Shape {
                appearance PBRAppearance { baseColor 0.3 0.3 0.38 roughness 0.5 metalness 0.25 }
                geometry Cylinder { height 0.018 radius 0.048 }
              }
            ]
          }

          # Neck column (Stewart linkage visual)
          Solid {
            translation 0 0 0.175
            name "neck_column"
            children [
              Shape {
                appearance PBRAppearance { baseColor 0.5 0.5 0.55 roughness 0.35 metalness 0.3 }
                geometry Cylinder { height 0.07 radius 0.022 }
              }
            ]
          }

          # Head sphere
          Solid {
            translation 0 0 0.26
            name "head_sphere"
            children [
              Shape {
                appearance PBRAppearance { baseColor 0.96 0.96 1.0 roughness 0.08 metalness 0 }
                geometry Sphere { radius 0.075 }
              }

              # Glasses frame (black strip across front of face)
              Solid {
                translation 0.065 0 0.01
                name "glasses"
                children [
                  Shape {
                    appearance PBRAppearance { baseColor 0.06 0.06 0.08 roughness 0.05 metalness 0.4 }
                    geometry Box { size 0.018 0.11 0.032 }
                  }
                ]
              }

              # Left eye lens
              Solid {
                translation 0.072 -0.03 0.01
                name "eye_left"
                children [
                  Shape {
                    appearance PBRAppearance { baseColor 0.04 0.04 0.06 roughness 0.04 metalness 0.1 }
                    geometry Sphere { radius 0.013 }
                  }
                ]
              }

              # Right eye lens
              Solid {
                translation 0.072 0.03 0.01
                name "eye_right"
                children [
                  Shape {
                    appearance PBRAppearance { baseColor 0.04 0.04 0.06 roughness 0.04 metalness 0.1 }
                    geometry Sphere { radius 0.013 }
                  }
                ]
              }

              # Left antenna (blue capsule, tilted)
              Solid {
                translation -0.008 0.04 0.088
                rotation 0.1 0 1 0.15
                name "antenna_left"
                children [
                  Shape {
                    appearance PBRAppearance { baseColor 0.18 0.55 1.0 roughness 0.2 metalness 0.1 }
                    geometry Capsule { height 0.08 radius 0.006 }
                  }
                ]
              }

              # Right antenna (blue capsule, tilted)
              Solid {
                translation -0.008 -0.04 0.088
                rotation 0.1 0 -1 0.15
                name "antenna_right"
                children [
                  Shape {
                    appearance PBRAppearance { baseColor 0.18 0.55 1.0 roughness 0.2 metalness 0.1 }
                    geometry Capsule { height 0.08 radius 0.006 }
                  }
                ]
              }
            ]
          }
        ]
        boundingObject Cylinder { height 0.22 radius 0.062 }
        physics Physics {}
      }
    }
  ]
}
