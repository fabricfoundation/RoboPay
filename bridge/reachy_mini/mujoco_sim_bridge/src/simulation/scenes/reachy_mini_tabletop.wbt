#VRML_SIM R2023b utf8

# Hugging Face Reachy Mini Tabletop Tracking Scene — Webots Sim-to-Sim Validation
# Full Webots scene with motorized joints for real physics simulation.

WorldInfo {
  info [
    "Hugging Face Reachy Mini — Webots Sim-to-Sim Cross-Simulator Validation"
  ]
  title "reachy_mini_tabletop_tracking"
  basicTimeStep 5
  FPS 60
}

Viewpoint {
  orientation -0.2 0.8 0.6 0.9
  position 1.5 -1.2 1.0
}

Background {
  skyColor [
    0.4 0.7 1
  ]
}

DirectionalLight {
  ambientLight 0.4 0.4 0.4
  color 1 1 1
  direction 0.5 0.5 -1
  intensity 1.5
  castShadows TRUE
}

DirectionalLight {
  ambientLight 0.2 0.2 0.2
  color 0.9 0.9 1
  direction -0.5 -0.5 -0.8
  intensity 0.8
  castShadows FALSE
}

# Wooden Table
Solid {
  translation 0.6 0 0.0
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.6 0.4 0.2
        roughness 0.5
      }
      geometry Box {
        size 0.8 1.0 0.05
      }
    }
  ]
  name "table"
  boundingObject Box {
    size 0.8 1.0 0.05
  }
}

# Apple
Solid {
  translation 0.6 -0.2 0.055
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.9 0.1 0.1
        roughness 0.2
      }
      geometry Sphere {
        radius 0.04
      }
    }
  ]
  name "apple"
  boundingObject Sphere {
    radius 0.04
  }
  physics Physics {
    density 300
  }
}

# Croissant
Solid {
  translation 0.6 0.1 0.055
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.8 0.5 0.2
        roughness 0.6
      }
      geometry Box {
        size 0.08 0.05 0.04
      }
    }
  ]
  name "croissant"
  boundingObject Box {
    size 0.08 0.05 0.04
  }
  physics Physics {
    density 200
  }
}

# Duck
Solid {
  translation 0.6 0.3 0.05
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.9 0.9 0.1
        roughness 0.3
      }
      geometry Sphere {
        radius 0.035
      }
    }
  ]
  name "duck"
  boundingObject Sphere {
    radius 0.035
  }
  physics Physics {
    density 100
  }
}

# Reachy Mini Robot — Supervisor controlled
Robot {
  translation 0 0 0.0
  children [
    # Base
    Solid {
      translation 0 0 0.05
      children [
        Shape {
          appearance PBRAppearance {
            baseColor 0.2 0.2 0.25
            roughness 0.4
          }
          geometry Cylinder {
            height 0.1
            radius 0.09
          }
        }
      ]
      boundingObject Cylinder {
        height 0.1
        radius 0.09
      }
      physics Physics {}
    }
    # Torso with Yaw Hinge
    HingeJoint {
      jointParameters HingeJointParameters {
        axis 0 0 1
        anchor 0 0 0.15
      }
      device [
        RotationalMotor {
          name "yaw_body"
          minPosition -2.79
          maxPosition 2.79
          maxVelocity 3.0
        }
        PositionSensor {
          name "yaw_body_sensor"
        }
      ]
      endPoint Solid {
        translation 0 0 0.15
        name "torso"
        children [
          Shape {
            appearance PBRAppearance {
              baseColor 0.92 0.92 0.96
              roughness 0.2
            }
            geometry Cylinder {
              height 0.16
              radius 0.065
            }
          }
          # Neck base
          Solid {
            translation 0 0 0.12
            name "neck_base"
            children [
              Shape {
                appearance PBRAppearance {
                  baseColor 0.35 0.35 0.4
                  roughness 0.4
                }
                geometry Cylinder {
                  height 0.02
                  radius 0.045
                }
              }
              # Head Unit
              Solid {
                translation 0 0 0.09
                name "head"
                children [
                  Shape {
                    appearance PBRAppearance {
                      baseColor 0.96 0.96 1.0
                      roughness 0.1
                    }
                    geometry Sphere {
                      radius 0.075
                    }
                  }
                  # Glasses
                  Solid {
                    translation 0.065 0.0 0.01
                    children [
                      Shape {
                        appearance PBRAppearance {
                          baseColor 0.1 0.1 0.12
                          roughness 0.1
                        }
                        geometry Box {
                          size 0.02 0.11 0.035
                        }
                      }
                    ]
                  }
                  # Left Eye
                  Solid {
                    translation 0.073 -0.03 0.01
                    children [
                      Shape {
                        appearance PBRAppearance {
                          baseColor 0.05 0.05 0.05
                          roughness 0.05
                        }
                        geometry Sphere {
                          radius 0.012
                        }
                      }
                    ]
                  }
                  # Right Eye
                  Solid {
                    translation 0.073 0.03 0.01
                    children [
                      Shape {
                        appearance PBRAppearance {
                          baseColor 0.05 0.05 0.05
                          roughness 0.05
                        }
                        geometry Sphere {
                          radius 0.012
                        }
                      }
                    ]
                  }
                  # Left Antenna
                  Solid {
                    translation 0.0 0.04 0.08
                    children [
                      Shape {
                        appearance PBRAppearance {
                          baseColor 0.2 0.6 1.0
                          roughness 0.2
                        }
                        geometry Capsule {
                          height 0.08
                          radius 0.006
                        }
                      }
                    ]
                  }
                  # Right Antenna
                  Solid {
                    translation 0.0 -0.04 0.08
                    children [
                      Shape {
                        appearance PBRAppearance {
                          baseColor 0.2 0.6 1.0
                          roughness 0.2
                        }
                        geometry Capsule {
                          height 0.08
                          radius 0.006
                        }
                      }
                    ]
                  }
                ]
                boundingObject Sphere {
                  radius 0.075
                }
                physics Physics {}
              }
            ]
          }
        ]
        boundingObject Cylinder {
          height 0.16
          radius 0.065
        }
        physics Physics {}
      }
    }
  ]
  name "reachy_mini"
  controller "reachy_mini_controller"
  supervisor TRUE
}
