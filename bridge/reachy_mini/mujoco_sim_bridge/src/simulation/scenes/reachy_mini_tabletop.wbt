#VRML_SIM R2023b utf8

# Hugging Face Reachy Mini Tabletop Scene — Webots Sim-to-Sim Validation
# Complete 3D Reachy Mini model with HingeJoint yaw_body motor.

WorldInfo {
  info [ "Hugging Face Reachy Mini — Webots Sim-to-Sim Validation" ]
  title "reachy_mini_tabletop"
  basicTimeStep 5
  FPS 60
}

Viewpoint {
  orientation -0.15 0.85 0.5 0.9
  position 1.6 -1.3 1.1
  follow "reachy_mini"
}

Background { skyColor [ 0.4 0.7 1.0 ] }

PointLight {
  attenuation 0 0 1
  color 1 1 1
  intensity 3
  location 0.5 -0.5 1.5
  castShadows TRUE
}

PointLight {
  attenuation 0 0 1
  color 0.9 0.9 1
  intensity 1.5
  location -0.5 0.5 1.2
}

# ── Wooden Table ───────────────────────────────────────────────────────────────
Solid {
  translation 0.6 0 0.0
  name "table"
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.55 0.38 0.18 roughness 0.6 }
      geometry Box { size 0.8 1.0 0.05 }
    }
  ]
  boundingObject Box { size 0.8 1.0 0.05 }
}

# ── Target Objects ─────────────────────────────────────────────────────────────
Solid {
  translation 0.6 -0.2 0.07
  name "APPLE"
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.92 0.12 0.08 roughness 0.2 }
      geometry Sphere { radius 0.04 }
    }
  ]
  boundingObject Sphere { radius 0.04 }
  physics Physics { density 300 }
}

Solid {
  translation 0.6 0.1 0.065
  name "CROISSANT"
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.82 0.52 0.18 roughness 0.7 }
      geometry Box { size 0.09 0.05 0.04 }
    }
  ]
  boundingObject Box { size 0.09 0.05 0.04 }
  physics Physics { density 200 }
}

Solid {
  translation 0.6 0.3 0.065
  name "DUCK"
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.95 0.95 0.05 roughness 0.3 }
      geometry Sphere { radius 0.04 }
    }
    Solid {
      translation 0.0 0 0.052
      children [
        Shape {
          appearance PBRAppearance { baseColor 0.95 0.95 0.05 roughness 0.3 }
          geometry Sphere { radius 0.025 }
        }
      ]
    }
    Solid {
      translation 0.025 0 0.055
      children [
        Shape {
          appearance PBRAppearance { baseColor 0.95 0.55 0.1 roughness 0.4 }
          geometry Box { size 0.02 0.012 0.008 }
        }
      ]
    }
  ]
  boundingObject Sphere { radius 0.05 }
  physics Physics { density 100 }
}

# ── Reachy Mini Robot (Full 3D Model with HingeJoint Motor) ───────────────────
Robot {
  translation 0 0 0.0
  name "reachy_mini"
  controller "reachy_mini_controller"
  supervisor TRUE
  children [

    # Base Footprint (Fixed)
    Solid {
      translation 0 0 0.05
      name "base_foot"
      children [
        Shape {
          appearance PBRAppearance { baseColor 0.2 0.2 0.25 roughness 0.45 }
          geometry Cylinder { height 0.1 radius 0.09 }
        }
      ]
      boundingObject Cylinder { height 0.1 radius 0.09 }
      physics Physics {}
    }

    # HingeJoint yaw_body — rotates the entire torso + neck + head assembly
    HingeJoint {
      jointParameters HingeJointParameters {
        axis 0 0 1
        anchor 0 0 0.1
      }
      device [
        RotationalMotor {
          name "yaw_body"
          minPosition -2.79
          maxPosition  2.79
          maxVelocity  3.0
        }
        PositionSensor { name "yaw_body_sensor" }
      ]
      endPoint Solid {
        translation 0 0 0.1
        name "torso"
        children [

          # Torso Shell
          Shape {
            appearance PBRAppearance { baseColor 0.93 0.93 0.97 roughness 0.15 }
            geometry Cylinder { height 0.22 radius 0.062 }
          }

          # Neck Base Plate
          Solid {
            translation 0 0 0.135
            name "neck_plate"
            children [
              Shape {
                appearance PBRAppearance { baseColor 0.3 0.3 0.38 roughness 0.5 }
                geometry Cylinder { height 0.018 radius 0.048 }
              }
            ]
          }

          # Neck Column (Stewart linkage visual)
          Solid {
            translation 0 0 0.175
            name "neck_column"
            children [
              Shape {
                appearance PBRAppearance { baseColor 0.5 0.5 0.55 roughness 0.35 }
                geometry Cylinder { height 0.07 radius 0.022 }
              }
            ]
          }

          # Head Sphere + Glasses + Eyes + Antennae
          Solid {
            translation 0 0 0.26
            name "head_sphere"
            children [

              # Head Sphere
              Shape {
                appearance PBRAppearance { baseColor 0.96 0.96 1.0 roughness 0.08 }
                geometry Sphere { radius 0.075 }
              }

              # Glasses Frame
              Solid {
                translation 0.065 0 0.01
                name "glasses"
                children [
                  Shape {
                    appearance PBRAppearance { baseColor 0.06 0.06 0.08 roughness 0.05 }
                    geometry Box { size 0.018 0.11 0.032 }
                  }
                ]
              }

              # Left Eye Lens
              Solid {
                translation 0.072 -0.03 0.01
                name "eye_left"
                children [
                  Shape {
                    appearance PBRAppearance { baseColor 0.04 0.04 0.06 roughness 0.04 }
                    geometry Sphere { radius 0.013 }
                  }
                ]
              }

              # Right Eye Lens
              Solid {
                translation 0.072 0.03 0.01
                name "eye_right"
                children [
                  Shape {
                    appearance PBRAppearance { baseColor 0.04 0.04 0.06 roughness 0.04 }
                    geometry Sphere { radius 0.013 }
                  }
                ]
              }

              # Left Antenna
              Solid {
                translation -0.008 0.04 0.088
                rotation 0.1 0 1 0.15
                name "antenna_left"
                children [
                  Shape {
                    appearance PBRAppearance { baseColor 0.18 0.55 1.0 roughness 0.2 }
                    geometry Capsule { height 0.08 radius 0.006 }
                  }
                ]
              }

              # Right Antenna
              Solid {
                translation -0.008 -0.04 0.088
                rotation 0.1 0 -1 0.15
                name "antenna_right"
                children [
                  Shape {
                    appearance PBRAppearance { baseColor 0.18 0.55 1.0 roughness 0.2 }
                    geometry Capsule { height 0.08 radius 0.006 }
                  }
                ]
              }
            ]
          }
        ]
        boundingObject Cylinder { height 0.22 radius 0.062 }
        physics Physics {}
      }
    }
  ]
}
